<%- include('partials/header', { 
    title: 'Buscar Usuarios - Artícora', 
    currentPage: 'search', 
    cssFile: 'search.css',
    searchQuery: typeof query !== 'undefined' ? query : ''
}) %>

<%
    const qParam = (typeof query !== 'undefined' && query) ? ('q=' + encodeURIComponent(query)) : '';
    const instParam = (typeof filters !== 'undefined' && filters.institution) ? ('institution=' + encodeURIComponent(filters.institution)) : '';
    const acadParam = (typeof filters !== 'undefined' && filters.academic) ? ('academic=' + encodeURIComponent(filters.academic)) : '';
    const verifiedParam = (typeof filters !== 'undefined' && filters.verified) ? 'verified=1' : '';
    const hasPicParam = (typeof filters !== 'undefined' && filters.hasPicture) ? 'hasPicture=1' : '';
    const anyFilterActive = Boolean((filters && (filters.verified || filters.hasPicture)) || (filters && (filters.institution && String(filters.institution).length > 0)) || (filters && filters.academic));
    const baseExtra = [instParam, acadParam, verifiedParam, hasPicParam].filter(Boolean).join('&');
    const baseParams = [qParam, baseExtra].filter(Boolean).join('&');
%>

<div class="container py-4">
    <div class="row mb-4">
        <div class="col-12">
            <h1 class="page-title mb-3">
                <i class="fas fa-user me-3"></i>Búsqueda de Usuarios
            </h1>

            <div class="search-box-container mb-4">
                <form action="/search-users" method="GET" class="search-form">
                    <div class="input-group input-group-lg">
                        <input type="text" class="form-control" name="q" 
                               placeholder="Buscar usuarios por @nombre, nombre completo o institución..." 
                               value="<%= typeof query !== 'undefined' ? query : '' %>"
                               aria-label="Buscar usuarios">
                        <button class="btn btn-primary" type="submit">
                            <i class="fas fa-search me-2"></i> Buscar
                        </button>
                    </div>
                </form>

                     <div class="mt-3 d-flex flex-wrap gap-2">
                          <span class="text-muted me-2">Filtrar:</span>
                          <a href="?<%= [qParam, 'verified=1'].filter(Boolean).join('&') %>" 
                              class="badge <%= (filters && filters.verified) ? 'bg-primary' : 'bg-light text-dark' %>">Verificados</a>
                          <a href="?<%= [qParam, 'hasPicture=1'].filter(Boolean).join('&') %>" 
                              class="badge <%= (filters && filters.hasPicture) ? 'bg-primary' : 'bg-light text-dark' %>">Con foto</a>
                          <a href="?<%= qParam %>" 
                              class="badge <%= !anyFilterActive ? 'bg-primary' : 'bg-light text-dark' %>">Todos</a>
                     </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-lg-3 mb-4">
            <div class="sticky-top" style="top: 20px;">
                <div class="card shadow-sm">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="fas fa-sliders-h me-2"></i>Filtros de usuario</h5>
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <label class="form-label small">Institución</label>
                            <input type="text" id="filterInstitution" class="form-control form-control-sm" placeholder="Ej. Universidad X" value="<%= (filters && filters.institution) ? filters.institution : '' %>">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small">Nivel académico</label>
                            <select id="filterAcademic" class="form-select form-select-sm">
                                <option value="" <%= !(filters && filters.academic) ? 'selected' : '' %>>Cualquiera</option>
                                <option value="Licenciatura" <%= (filters && filters.academic === 'Licenciatura') ? 'selected' : '' %>>Licenciatura</option>
                                <option value="Maestría" <%= (filters && filters.academic === 'Maestría') ? 'selected' : '' %>>Maestría</option>
                                <option value="Doctorado" <%= (filters && filters.academic === 'Doctorado') ? 'selected' : '' %>>Doctorado</option>
                                <option value="Estudiante" <%= (filters && filters.academic === 'Estudiante') ? 'selected' : '' %>>Estudiante</option>
                                <option value="Profesional" <%= (filters && filters.academic === 'Profesional') ? 'selected' : '' %>>Profesional</option>
                            </select>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="onlyVerified" <%= (filters && filters.verified) ? 'checked' : '' %>>
                            <label class="form-check-label" for="onlyVerified">Solo verificados</label>
                        </div>
                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="onlyHasPicture" <%= (filters && filters.hasPicture) ? 'checked' : '' %>>
                            <label class="form-check-label" for="onlyHasPicture">Solo con foto</label>
                        </div>
                        <div class="d-grid gap-2">
                            <button type="button" class="btn btn-primary" id="applyUserFiltersBtn">Aplicar</button>
                            <button type="button" class="btn btn-outline-secondary" id="resetUserFiltersBtn">Restablecer</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-9">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h5 class="mb-0">
                        <%= results.length %> usuario<%= results.length !== 1 ? 's' : '' %>
                        <% if (typeof query !== 'undefined' && query) { %>
                            para "<strong><%= query %></strong>"
                        <% } %>
                    </h5>
                </div>
            </div>

            <div id="searchResults">
                <% if (results && results.length > 0) { %>
                    <div class="results-list">
                        <% results.forEach(u => { %>
                            <div class="card user-card mb-3">
                                <div class="card-body">
                                    <div class="row align-items-center">
                                        <div class="col-auto">
                                            <a href="/profile/<%= u.id %>">
                                                <% if (u.profile_picture) { %>
                                                    <img src="<%= u.profile_picture %>" alt="avatar" class="rounded-circle" width="64" height="64">
                                                <% } else { %>
                                                    <div class="user-avatar" style="width:64px;height:64px;font-size:20px;display:flex;align-items:center;justify-content:center;border-radius:50%;background:#6c757d;color:#fff;">
                                                        <%= (u.full_name || u.username || 'U').charAt(0).toUpperCase() %>
                                                    </div>
                                                <% } %>
                                            </a>
                                        </div>
                                        <div class="col">
                                            <h6 class="mb-1">
                                                <a href="/profile/<%= u.id %>" class="text-decoration-none"><%= u.full_name || u.username %></a>
                                                <small class="text-muted">@<%= u.username %></small>
                                                <% if (u.is_verified) { %>
                                                    <span class="badge bg-success ms-2">Verificado</span>
                                                <% } %>
                                            </h6>
                                            <div class="small text-muted">
                                                <%= u.institution || '' %> <span class="mx-2">•</span> <%= u.academic_level || '' %>
                                            </div>
                                        </div>
                                        <div class="col-auto">
                                            <a href="/profile/<%= u.id %>" class="btn btn-outline-primary">Ver perfil</a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>

                    <% if (pagination && pagination.totalPages > 1) { %>
                        <nav aria-label="Paginación de usuarios">
                            <ul class="pagination justify-content-center">
                                <li class="page-item <%= pagination.currentPage === 1 ? 'disabled' : '' %>">
                                    <a class="page-link" href="?page=<%= pagination.currentPage - 1 %><%= baseParams ? '&' + baseParams : '' %>">
                                        <i class="fas fa-chevron-left"></i>
                                    </a>
                                </li>
                                <% for (let i = 1; i <= pagination.totalPages; i++) { %>
                                    <% if (i === pagination.currentPage) { %>
                                        <li class="page-item active"><span class="page-link"><%= i %></span></li>
                                    <% } else { %>
                                        <li class="page-item"><a class="page-link" href="?page=<%= i %><%= baseParams ? '&' + baseParams : '' %>"><%= i %></a></li>
                                    <% } %>
                                <% } %>
                                <li class="page-item <%= pagination.currentPage === pagination.totalPages ? 'disabled' : '' %>">
                                    <a class="page-link" href="?page=<%= pagination.currentPage + 1 %><%= baseParams ? '&' + baseParams : '' %>">
                                        <i class="fas fa-chevron-right"></i>
                                    </a>
                                </li>
                            </ul>
                        </nav>
                    <% } %>
                <% } else { %>
                    <div class="card shadow-sm">
                        <div class="card-body text-center py-5">
                            <div class="empty-state-icon mb-4">
                                <i class="fas fa-user fa-3x text-muted"></i>
                            </div>
                            <h4 class="mb-3">No se encontraron usuarios</h4>
                            <p class="text-muted mb-4">
                                <% if (typeof query !== 'undefined' && query) { %>
                                    No hay usuarios que coincidan con "<strong><%= query %></strong>".
                                <% } else { %>
                                    No hay usuarios para mostrar.
                                <% } %>
                            </p>
                            <div class="d-flex justify-content-center gap-3">
                                <a href="/" class="btn btn-outline-secondary">
                                    <i class="fas fa-home me-2"></i> Volver al inicio
                                </a>
                            </div>
                        </div>
                    </div>
                <% } %>
            </div>
        </div>
    </div>
</div>

<%- include('partials/footer', { jsFile: 'search.js' }) %>
