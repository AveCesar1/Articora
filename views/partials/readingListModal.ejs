<!-- Reading list modal (used in post and dashboard) -->
<link rel="stylesheet" href="/css/readingListModal.css">
<!-- Modal: readingListModal -->
<div class="modal fade" id="readingListModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-scrollable">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title"><i class="fas fa-bookmark me-2"></i>Mi Lista de Lectura</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body">
        <ul class="nav nav-tabs" id="readingListTabs" role="tablist">
          <li class="nav-item" role="presentation">
            <button class="nav-link active" id="tab-to-read" data-bs-toggle="tab" data-bs-target="#tabToRead" type="button" role="tab" aria-controls="tabToRead" aria-selected="true">
              Para leer después <span id="toReadLimitText" class="badge bg-secondary ms-2"></span>
            </button>
          </li>
          <li class="nav-item" role="presentation">
            <button class="nav-link" id="tab-reads" data-bs-toggle="tab" data-bs-target="#tabReads" type="button" role="tab" aria-controls="tabReads" aria-selected="false">
              Historial de lecturas
            </button>
          </li>
        </ul>

        <div class="tab-content mt-3">
          <div class="tab-pane fade show active" id="tabToRead" role="tabpanel" aria-labelledby="tab-to-read">
            <div id="toReadList" class="list-group"></div>
            <div class="mt-3 text-muted small">Arrastra o usa las flechas para reordenar. Mover a leídas eliminará la entrada de pendientes.</div>
          </div>
          <div class="tab-pane fade" id="tabReads" role="tabpanel" aria-labelledby="tab-reads">
            <div id="readHistoryList" class="list-group"></div>
            <div class="mt-3 text-muted small">Puedes editar la fecha (solo pasado o actual) o eliminar el registro.</div>
          </div>
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
      </div>
    </div>
  </div>
</div>

<!-- Small modal to mark a single source as read with date selection -->
<div class="modal fade" id="markReadModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Marcar como leída</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
      </div>
      <div class="modal-body">
        <p class="small text-muted">Selecciona la fecha de lectura (pasada o hoy). Dejar vacío usará la fecha actual.</p>
        <div class="mb-3">
          <label for="markReadDate" class="form-label">Fecha</label>
          <input type="date" id="markReadDate" class="form-control" max="<%= new Date().toISOString().slice(0,10) %>">
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
        <button type="button" class="btn btn-primary" id="confirmMarkReadBtn" data-source-id="">Marcar como leída</button>
      </div>
    </div>
  </div>
</div>
