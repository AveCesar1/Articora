<%- include('partials/header', { title: 'Registro', pageStyles: '/css/register.css', isAuthenticated: false }) %>

    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow">
                <div class="card-header text-center">
                    <h4 class="mb-0">Crear una cuenta en Artícora</h4>
                </div>
                <div class="card-body p-4">
                    <form id="registerForm" action="/register" method="POST">
                        <input type="hidden" id="publicKey" name="publicKey">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="username" class="form-label">Nombre de usuario *</label>
                                <input type="text" class="form-control" id="username" placeholder="Entre 5 y 15 caracteres (solo letras y números)" required minlength="5" maxlength="15" pattern="[A-Za-z0-9]+">
                                <div class="form-text">Este será tu nombre público en la plataforma.</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="email" class="form-label">Correo electrónico *</label>
                                <input type="email" class="form-control" id="email" placeholder="ejemplo@correo.com" required>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label for="password" class="form-label">Contraseña *</label>
                                <div class="input-group">
                                    <input type="password" class="form-control" id="password" placeholder="Entre 8 y 22 caracteres" required minlength="8" maxlength="22">
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePasswordVisibility('password')">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                                <div class="form-text">Puede incluir cualquier carácter (letras, números, símbolos).</div>
                            </div>
                            <div class="col-md-6 mb-3">
                                <label for="confirmPassword" class="form-label">Confirmar contraseña *</label>
                                <div class="input-group">
                                    <input type="password" class="form-control" id="confirmPassword" placeholder="Repite tu contraseña" required>
                                    <button class="btn btn-outline-secondary" type="button" onclick="togglePasswordVisibility('confirmPassword')">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="terms" required>
                                <label class="form-check-label" for="terms">
                                    Acepto los <a href="/terms">Términos de servicio</a> y la <a href="/privacy">Política de privacidad</a> de Artícora.
                                </label>
                            </div>
                        </div>
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary">Crear cuenta</button>
                        </div>
                        <hr class="my-4">
                        <p class="text-center mb-0">¿Ya tienes una cuenta? <a href="/login">Inicia sesión aquí</a></p>
                    </form>
                    <div id="error-message" class="alert alert-danger d-none d-flex align-items-center" role="alert">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        <span id="error-text"></span>
                    </div>
                    <div id="success-message" class="alert alert-success d-none d-flex align-items-center" role="alert">
                        <i class="fas fa-check-circle me-2"></i>
                        <span id="success-text"></span>
                    </div>
                </div>
            </div>
            <div class="text-center mt-4">
                <p>Después del registro, deberás verificar tu correo electrónico para activar tu cuenta.</p>
                <p>Si eres académico, podrás luego validar tu cuenta para subir fuentes y crear grupos.</p>
            </div>
        </div>
    </div>

<script src="/js/crypto.js"></script>

<!-- Modal: Completar perfil después de verificar correo -->
<div class="modal fade" id="completeRegistrationModal" tabindex="-1" aria-labelledby="completeRegistrationLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="completeRegistrationLabel">Cuéntanos más sobre ti</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <form id="completeRegistrationForm">
                <div class="modal-body">
                    <div id="complete-error" class="alert alert-danger d-none" role="alert"></div>
                    <div id="complete-success" class="alert alert-success d-none" role="alert"></div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="firstName" class="form-label">Nombre(s)</label>
                            <input type="text" class="form-control" id="firstName" maxlength="50" placeholder="Tus nombres (opcional)">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="lastName" class="form-label">Apellido(s)</label>
                            <input type="text" class="form-control" id="lastName" maxlength="50" placeholder="Tus apellidos (opcional)">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="academicLevel" class="form-label">Grado académico</label>
                        <select id="academicLevel" class="form-select">
                            <option value="">Selecciona...</option>
                            <option>Licenciatura</option>
                            <option>Maestría</option>
                            <option>Doctorado</option>
                            <option>Estudiante</option>
                            <option>Profesional</option>
                        </select>
                        <div class="form-text">Selecciona el grado que mejor te describa.</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="institution" class="form-label">Institución</label>
                            <input type="text" class="form-control" id="institution" maxlength="255" placeholder="Opcional">
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="department" class="form-label">Departamento</label>
                            <input type="text" class="form-control" id="department" maxlength="255" placeholder="Opcional">
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="interestInput" class="form-label">Intereses de investigación (mínimo 3)</label>
                        <div class="input-group mb-2">
                            <input type="text" id="interestInput" class="form-control" maxlength="100" placeholder="Escribe un interés y pulsa Agregar">
                            <button type="button" id="addInterestBtn" class="btn btn-outline-secondary">Agregar</button>
                        </div>
                        <div id="interestsList" class="mb-2"></div>
                        <div class="form-text">Añade al menos 3 intereses. Escribe uno y pulsa "Agregar".</div>
                    </div>

                    <div class="mb-3 form-check">
                        <input type="checkbox" class="form-check-input" id="availableForMessages">
                        <label class="form-check-label" for="availableForMessages">Disponible para recibir mensajes</label>
                    </div>

                    <div class="mb-3">
                        <label for="bio" class="form-label">Biografía</label>
                        <textarea id="bio" class="form-control" rows="4" maxlength="1000" placeholder="Escribe una breve biografía (máx. 1000 caracteres)"></textarea>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" id="complete-submit-btn" class="btn btn-primary">Guardar y finalizar</button>
                </div>
            </form>
        </div>
    </div>
</div>

<%- include('partials/footer', { pageScripts: '/js/register.js' }) %>