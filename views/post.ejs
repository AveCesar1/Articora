            <div class="modal-header">
                <h5 class="modal-title" id="commentConfirmModalLabel">Confirmar comentario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <p id="commentConfirmBody">¿Estás seguro de que quieres publicar este comentario?</p>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="commentConfirmBtn">Sí, publicar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal para editar comentario y calificación -->
<div class="modal fade" id="editCommentModal" tabindex="-1" aria-labelledby="editCommentModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="editCommentModalLabel">Editar comentario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="editCommentText" class="form-label">Comentario</label>
                    <textarea class="form-control" id="editCommentText" rows="4"></textarea>
                    <small class="text-muted">Solo texto plano. Máx 1000 caracteres.</small>
                </div>

                <% const editCriteria = [ {id:'readability', label:'Extensión de lectura'}, {id:'completeness', label:'Completitud'}, {id:'detail_level', label:'Nivel de detalle'}, {id:'veracity', label:'Veracidad'}, {id:'technical_difficulty', label:'Dificultad técnica'} ]; %>
                <% editCriteria.forEach(c => { %>
                    <div class="mb-3">
                        <label class="form-label"><%= c.label %></label>
                        <div class="star-rating" tabindex="0" data-criterion="<%= c.id %>" data-target-id="edit_rating_<%= c.id %>" style="font-size:1.4rem; cursor:pointer;">
                            <% for (let s = 1; s <= 5; s++) { %>
                                <i class="far fa-star star" data-star="<%= s %>"></i>
                            <% } %>
                        </div>
                        <input type="hidden" id="edit_rating_<%= c.id %>" value="5">
                    </div>
                <% }) %>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary" id="saveEditCommentBtn">Guardar cambios</button>
            </div>
        </div>
    </div>
</div>

<script>
    // Load post-rate.js after all other scripts (bootstrap) have been loaded
    window.addEventListener('load', function() {
        var s = document.createElement('script');
        s.src = '/js/post-rate.js';
        s.async = false; // ensure execution order and immediate run after insertion
        document.body.appendChild(s);
    });
</script>

