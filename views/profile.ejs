<%- include('partials/header', 
    { 
        title: 'Perfil - Artícora', 
        currentPage: 'profile', 
        cssFile: 'profile.css' 
    }
    ) 
%>

<div class="container py-5">
    <% if (typeof canViewFullProfile !== 'undefined' && !canViewFullProfile) { %>
        <div class="row">
            <div class="col-12">
                <div class="card shadow text-center py-5">
                    <div class="card-body">
                        <img src="<%= user.profile_picture ? user.profile_picture : ('https://placehold.co/200x200/2c1810/e0d6c2?text=' + encodeURIComponent((user.fullName || '').charAt(0))) %>" alt="Avatar" class="profile-avatar mb-4">
                        <h3 class="mb-2">Perfil privado</h3>
                        <p class="text-muted mb-3">Este usuario ha configurado su perfil como privado. No tienes permiso para ver su información.</p>
                        <div class="d-flex justify-content-center">
                            <a href="/search" class="btn btn-outline-primary me-2">Buscar usuarios</a>
                            <a href="/dashboard" class="btn btn-secondary">Ir a mi dashboard</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    <% } else { %>
    <!-- Tarjeta principal del perfil -->
    <div class="card profile-header-card shadow-lg mb-5">
        <div class="card-body">
            <div class="row align-items-center">
                <!-- Columna izquierda: Avatar y datos básicos -->
                <div class="col-md-4 text-center mb-4 mb-md-0">
                    <img src="<%= user.profile_picture ? user.profile_picture : ('https://placehold.co/200x200/2c1810/e0d6c2?text=' + encodeURIComponent((user.fullName || '').charAt(0))) %>" 
                         alt="Foto de perfil" class="profile-avatar mb-4">
                    
                    <h2 class="profile-name mb-2"><%= user.fullName %></h2>
                    <p class="text-muted mb-2">@<%= user.username %></p>
                    
                    <span class="status-badge validated mb-3">
                        <i class="fas fa-check-circle me-1"></i> <%= user.academicStatus %>
                    </span>
                    
                    <div class="mt-3">
                        <% if (isOwnProfile) { %>
                            <a href="/profile/config" class="btn btn-primary">
                                <i class="fas fa-edit me-2"></i> Editar perfil
                            </a>
                        <% } else { %>
                            <% if (user.availableForMessages) { %>
                                <% if (user.canSendRequest) { %>
                                    <button class="btn btn-primary send-contact-request" data-user-id="<%= user.id %>">
                                        <i class="fas fa-user-plus me-2"></i> Enviar solicitud de contacto
                                    </button>
                                <% } else if (user.hasPendingRequest) { %>
                                    <button class="btn btn-secondary" disabled>
                                        <i class="fas fa-clock me-2"></i> Solicitud pendiente
                                    </button>
                                <% } else { %>
                                    <button class="btn btn-secondary" disabled>
                                        <i class="fas fa-ban me-2"></i> No disponible
                                    </button>
                                <% } %>
                            <% } else { %>
                                <button class="btn btn-secondary" disabled>
                                    <i class="fas fa-ban me-2"></i> No disponible para mensajes
                                </button>
                            <% } %>
                                <div class="mt-3">
                                    <button class="btn btn-outline-danger" id="reportUserBtn">
                                        <i class="fas fa-flag me-2"></i> Reportar usuario
                                    </button>
                                </div>
                        <% } %>
                    </div>
                </div>
                
                <!-- Columna derecha: Información detallada -->
                <div class="col-md-8">
                    <div class="row mb-4">
                        <div class="col-md-6">
                            <h5 class="section-title mb-3">
                                <i class="fas fa-graduation-cap me-2"></i>Información académica
                            </h5>
                            <div class="info-item mb-2">
                                <strong>Grado:</strong> <%= user.academicDegree %>
                            </div>
                            <div class="info-item mb-2">
                                <strong>Institución:</strong> <%= user.institution %>
                            </div>
                            <div class="info-item mb-2">
                                <strong>Miembro desde:</strong> <%= user.joinDate %>
                            </div>
                            <div class="info-item">
                                <strong>Disponible para mensajes:</strong>
                                <% if (user.availableForMessages) { %>
                                    <span class="text-success">Sí</span>
                                <% } else { %>
                                    <span class="text-danger">No</span>
                                <% } %>
                            </div>
                        </div>
                        
                        <div class="col-md-6">
                            <h5 class="section-title mb-3">
                                <i class="fas fa-chart-bar me-2"></i>Estadísticas
                            </h5>
                            <div class="profile-stats">
                                <div class="stat">
                                    <span class="stat-value"><%= user.stats.sourcesAdded %></span>
                                    <span class="stat-label">Fuentes subidas</span>
                                </div>
                                <div class="stat">
                                    <span class="stat-value"><%= user.stats.reviewsWritten %></span>
                                    <span class="stat-label">Reseñas escritas</span>
                                </div>
                                <div class="stat">
                                    <span class="stat-value"><%= user.stats.readingLists %></span>
                                    <span class="stat-label">Listas creadas</span>
                                </div>
                                <div class="stat">
                                    <span class="stat-value"><%= user.stats.collaborations %></span>
                                    <span class="stat-label">Colaboraciones</span>
                                </div>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Biografía -->
                    <div class="mb-4">
                        <h5 class="section-title mb-3">
                            <i class="fas fa-book-open me-2"></i>Biografía
                        </h5>
                        <div class="profile-bio p-3 border-left-accent">
                            <%= user.bio %>
                        </div>
                    </div>
                    
                    <!-- Intereses -->
                    <div>
                        <h5 class="section-title mb-3">
                            <i class="fas fa-tags me-2"></i>Intereses de investigación
                        </h5>
                        <div class="interests-container">
                            <% user.interests.forEach(interest => { %>
                                <span class="category-badge">
                                    <i class="fas fa-hashtag me-1"></i><%= interest %>
                                </span>
                            <% }) %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Segunda fila: Gráfica de radar y actividad -->
    <div class="row">
        <!-- Columna izquierda: Actividad reciente -->
        <div class="col-lg-8 mb-4">
            <div class="card shadow h-100">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-history me-2"></i>Actividad reciente
                    </h5>
                </div>
                <div class="card-body">
                    <div class="activity-list">
                        <% if (user.recentActivity && user.recentActivity.length > 0) { %>
                            <% user.recentActivity.slice(0, 4).forEach(activity => { %>
                                <div class="activity-item">
                                    <div class="activity-icon">
                                        <% if (activity.type === 'reading') { %>
                                            <i class="fas fa-book-reader"></i>
                                        <% } else if (activity.type === 'upload') { %>
                                            <i class="fas fa-upload"></i>
                                        <% } else if (activity.type === 'review') { %>
                                            <i class="fas fa-star"></i>
                                        <% } else { %>
                                            <i class="far fa-clock"></i>
                                        <% } %>
                                    </div>
                                    <div class="activity-content">
                                        <h6 class="activity-title"><%= activity.title %></h6>
                                        <% if (activity.category) { %>
                                            <p class="activity-description"><%= activity.category %></p>
                                        <% } %>
                                        <span class="activity-time">
                                            <i class="far fa-clock me-1"></i><%= activity.date %>
                                        </span>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else { %>
                            <div class="text-center text-muted py-5">
                                <i class="far fa-clock fa-2x mb-3"></i>
                                <h6 class="mb-1">No hay actividad reciente</h6>
                                <p class="mb-0">Tus acciones aparecerán aquí cuando interactúes en la plataforma.</p>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Columna derecha: Gráfica de radar -->
        <div class="col-lg-4 mb-4">
            <div class="card shadow h-100">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-chart-radar me-2"></i>Distribución de lecturas
                    </h5>
                </div>
                <div class="card-body">
                    <div class="d-flex flex-column align-items-center" 
                        style="display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%;"
                        >
                        <div class="radar-container">
                            <canvas id="readingRadarChart" height="300"></canvas>
                        </div>
                        <div class="text-center mt-3">
                            <p class="text-muted small mb-0">
                                <i class="fas fa-info-circle me-1"></i>
                                Gráfico de radar basado en lecturas registradas
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Tercera fila: Listas curatoriales -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card shadow">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-list-ul me-2"></i>Listas curatoriales
                    </h5>
                </div>
                <div class="card-body">
                    <% if (user.lists && user.lists.length > 0) { %>
                        <div class="row">
                            <% user.lists.forEach(list => { %>
                                <div class="col-md-4 mb-3">
                                    <div class="card list-card h-100">
                                        <div class="card-body">
                                            <div class="d-flex justify-content-between align-items-start mb-3">
                                                <h6 class="card-title mb-0"><%= list.title %></h6>
                                                <span class="badge bg-primary"><%= list.total_sources || 0 %> fuentes</span>
                                            </div>
                                            <p class="card-text small"><%= list.description || '' %></p>
                                            <div class="mt-3">
                                                <% if (list.tags) { %>
                                                    <% list.tags.split(',').slice(0,3).forEach(tag => { %>
                                                        <span class="badge bg-light text-dark me-1"><%= tag.trim() %></span>
                                                    <% }) %>
                                                <% } %>
                                            </div>
                                        </div>
                                        <div class="card-footer bg-transparent border-top-0">
                                            <small class="text-muted">
                                                <i class="far fa-eye me-1"></i> <%= list.total_views || 0 %> visualizaciones
                                            </small>
                                        </div>
                                    </div>
                                </div>
                            <% }) %>
                        </div>
                    <% } else { %>
                        <div class="text-center text-muted py-5">
                            <i class="fas fa-list-ul fa-2x mb-3"></i>
                            <h6 class="mb-1">No hay listas curatoriales</h6>
                            <p class="mb-0">Este usuario no ha creado listas curatoriales aún.</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

    <% } %>

<!-- Script para Chart.js -->
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<!-- Datos de lectura para el servidor -->
<script id="readingStatsData" type="application/json">
    <%- JSON.stringify(user.readingStats) %>
</script>

<!-- Datos de actividad reciente para el servidor -->
<script id="recentActivityData" type="application/json">
    <%- JSON.stringify(user.recentActivity) %>
</script>
<%- include('partials/readingListModal.ejs') %>

<!-- Script para pasar datos del servidor al frontend -->
<script>
    // Exponer información de permisos y proteger parseo JSON
    const isOwnProfile = <%= isOwnProfile ? 'true' : 'false' %>;
    const profileRadarPublic = <%= (user.dashboardSettings && user.dashboardSettings.radarChartPublic) ? 'true' : 'false' %>;

    // Leer datos del elemento HTML (evita error de sintaxis)
    const readingStatsElement = document.getElementById('readingStatsData');
    let readingStats = [];
    try {
        const txt = readingStatsElement && readingStatsElement.textContent ? readingStatsElement.textContent.trim() : '';
        if (txt) {
            readingStats = JSON.parse(txt);
        }
    } catch (e) {
        console.error('Error parsing readingStatsData', e && e.message);
        readingStats = [];
    }

    // Ensure we have an array of length 8
    if (!Array.isArray(readingStats)) {
        const tmp = new Array(8).fill(0);
        if (readingStats && typeof readingStats === 'object') {
            Object.keys(readingStats).forEach(k => {
                const idx = parseInt(k, 10) - 1;
                if (!Number.isNaN(idx) && idx >= 0 && idx < 8) tmp[idx] = readingStats[k] || 0;
            });
        }
        readingStats = tmp;
    } else {
        // pad/truncate to 8
        readingStats = readingStats.slice(0,8).concat(new Array(8).fill(0)).slice(0,8);
    }

    const recentActivityElement = document.getElementById('recentActivityData');
    let recentActivity = [];
    try {
        const txt2 = recentActivityElement && recentActivityElement.textContent ? recentActivityElement.textContent.trim() : '';
        if (txt2) recentActivity = JSON.parse(txt2);
    } catch (e) {
        console.error('Error parsing recentActivityData', e && e.message);
        recentActivity = [];
    }

    const radarData = {
        labels: [
            'Ciencias Cognitivas',
            'Ciencias Sociales', 
            'Ciencias Humanistas',
            'Disciplinas Creativas',
            'Ciencias Computacionales',
            'Ciencias Exactas',
            'Ciencias Naturales',
            'Ciencias Aplicadas'
        ],
        datasets: [{
            label: 'Lecturas por categoría',
            data: [
                readingStats[0], // cognitiveSciences
                readingStats[1], // socialSciences
                readingStats[2], // humanities
                readingStats[3], // creativeDisciplines
                readingStats[4], // computationalSciences
                readingStats[5], // exactSciences
                readingStats[6], // naturalSciences
                readingStats[7]  // appliedSciences
                // TODO: the array ID should be categories.id. Not a hardcoded order.
            ],
            backgroundColor: 'rgba(183, 147, 76, 0.2)',
            borderColor: 'rgba(183, 147, 76, 1)',
            borderWidth: 2,
            pointBackgroundColor: 'rgba(183, 147, 76, 1)',
            pointBorderColor: '#fff',
            pointHoverBackgroundColor: '#fff',
            pointHoverBorderColor: 'rgba(183, 147, 76, 1)',
            pointRadius: 4,
            pointHoverRadius: 6
        }]
    };
    
    // If viewing another user's profile and they have disabled the radar, show a grey placeholder dataset
    const radarAllowed = isOwnProfile || profileRadarPublic;

    if (!radarAllowed) {
        // datos grises de relleno (ya los tienes)
        radarData.datasets[0].data = new Array(8).fill(1);
        radarData.datasets[0].backgroundColor = 'rgba(120,120,120,0.12)';
        radarData.datasets[0].borderColor = 'rgba(120,120,120,0.6)';
        radarData.datasets[0].pointBackgroundColor = 'rgba(94,94,94,0.1)';

        // Función para agregar overlay centrado con desenfoque
        function addRadarOverlay(message) {
            const container = document.querySelector('.radar-container');
            if (!container) return;
            // Asegurar posicionamiento relativo para que el overlay se posicione respecto al contenedor
            container.style.position = 'relative';
            // Eliminar overlay previo si existe
            const existingOverlay = container.querySelector('.radar-overlay');
            if (existingOverlay) existingOverlay.remove();

            const overlay = document.createElement('div');
            overlay.className = 'radar-overlay';
            overlay.innerHTML = `<div class="overlay-content">${message}</div>`;
            // Estilos para centrar y aplicar blur sin fondo blanco sólido
            overlay.style.position = 'absolute';
            overlay.style.top = '0';
            overlay.style.left = '0';
            overlay.style.width = '100%';
            overlay.style.height = '100%';
            overlay.style.display = 'flex';
            overlay.style.alignItems = 'center';
            overlay.style.justifyContent = 'center';
            overlay.style.backdropFilter = 'blur(6px)';   // desenfoque de fondo
            overlay.style.backgroundColor = 'rgba(0, 0, 0, 0.25)'; // toque oscuro sutil, no blanco
            overlay.style.borderRadius = '8px';           // opcional: acorde al diseño
            overlay.style.pointerEvents = 'none';         // para no bloquear clics si luego quieres interacción
            overlay.style.textAlign = 'center';
            overlay.style.padding = '1rem';
            overlay.style.zIndex = '10';
            // Estilo del texto
            const content = overlay.querySelector('.overlay-content');
            content.style.color = '#fff';
            content.style.fontFamily = "'Palatino Linotype', 'Book Antiqua', serif";
            content.style.fontSize = '1rem';
            content.style.fontWeight = '500';
            content.style.textShadow = '0 1px 2px rgba(0,0,0,0.3)';
            content.style.backgroundColor = 'transparent';
            content.style.padding = '0.5rem 1rem';
            content.style.borderRadius = '2rem';
            content.style.backdropFilter = 'blur(2px)'; // opcional doble desenfoque

            container.appendChild(overlay);
        }

        addRadarOverlay('⚠️ El usuario no ha permitido mostrar estas estadísticas.');
    }

    var radarConfig = {
        type: 'radar',
        data: radarData,
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                r: {
                    angleLines: {
                        color: 'rgba(141, 110, 99, 0.3)'
                    },
                    grid: {
                        color: 'rgba(141, 110, 99, 0.1)'
                    },
                    pointLabels: {
                        color: '#3e2723',
                        font: {
                            family: "'Palatino Linotype', 'Book Antiqua', serif",
                            size: 11
                        }
                    },
                    ticks: {
                        backdropColor: 'transparent',
                        color: '#3e2723',
                        font: {
                            family: "'Georgia', 'Times New Roman', serif",
                            size: 10
                        },
                        stepSize: 5
                    },
                    beginAtZero: true,
                    suggestedMin: 0,
                    suggestedMax: Math.max(...radarData.datasets[0].data)
                }
            },
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        color: '#3e2723',
                        font: {
                            family: "'Palatino Linotype', 'Book Antiqua', serif",
                            size: 12
                        },
                        padding: 20
                    }
                }
            }
        }
    };
</script>

<!-- Modal para reportar usuario -->
<div class="modal fade" id="reportUserModal" tabindex="-1" aria-labelledby="reportUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="reportUserModalLabel">Reportar usuario</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <form id="reportUserForm">
                    <input type="hidden" id="reportUser_target_type" value="user">
                    <input type="hidden" id="reportUser_reported_user_id" value="<%= user.id %>">

                    <div class="mb-3">
                        <label for="reportUserReason" class="form-label">Motivo</label>
                        <select class="form-select" id="reportUserReason" required>
                            <option value="informacion_falsa">Información falsa en perfil</option>
                            <option value="publicaciones_problemas">Publicaciones problemáticas (fuentes eliminadas previamente)</option>
                            <option value="otro">Otro</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label for="reportUserDetails" class="form-label">Detalles (opcional)</label>
                        <textarea id="reportUserDetails" class="form-control" rows="3" maxlength="2000" placeholder="Describe brevemente por qué consideras que este usuario debe ser revisado..."></textarea>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-danger" id="submitReportUserBtn">Enviar reporte</button>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function(){
    const reportUserBtn = document.getElementById('reportUserBtn');
    const reportUserModalEl = document.getElementById('reportUserModal');
    const reportUserModal = new bootstrap.Modal(reportUserModalEl);

    if (reportUserBtn) {
        reportUserBtn.addEventListener('click', () => {
            reportUserModal.show();
        });
    }

    document.getElementById('submitReportUserBtn').addEventListener('click', async () => {
        const reportedUserId = document.getElementById('reportUser_reported_user_id').value || null;
        const reason = document.getElementById('reportUserReason').value || '';
        const description = document.getElementById('reportUserDetails').value || '';

        try {
            const resp = await fetch('/api/reports', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                credentials: 'same-origin',
                body: JSON.stringify({ type: 'user', source_id: null, comment_id: null, reported_user_id: reportedUserId ? Number(reportedUserId) : null, reason, description })
            });
            const data = await resp.json();
            if (resp.ok && data && data.success) {
                reportUserModal.hide();
                alert('Reporte enviado. Gracias por colaborar con la moderación.');
            } else {
                alert('Error al enviar el reporte: ' + (data && data.message ? data.message : resp.statusText));
            }
        } catch (e) {
            console.error('Report user error', e);
            alert('Error al enviar el reporte');
        }
    });
});
</script>

<%- include('partials/footer', { jsFile: 'profile.js' }) %>